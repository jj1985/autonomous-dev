{
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/post_compact_enricher.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/plan_mode_exit_detector.py",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      },
      {
        "hooks": [
          {
            "command": "ACTIVITY_LOGGING=true python3 ~/.claude/hooks/session_activity_logger.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bash ~/.claude/hooks/pre_compact_batch_saver.sh",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "MCP_AUTO_APPROVE=true SANDBOX_ENABLED=false python3 ~/.claude/hooks/unified_pre_tool.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/stop_quality_gate.py",
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/unified_session_tracker.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/task_completed_handler.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 ~/.claude/hooks/unified_prompt_validator.py",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "permissionBatching": {
    "enabled": true
  },
  "permissions": {
    "allow": [
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "NotebookEdit",
      "Task",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "ExitPlanMode",
      "BashOutput",
      "KillShell",
      "AskUserQuestion",
      "Skill",
      "SlashCommand",
      "EnterPlanMode",
      "AgentOutputTool",
      "Agent",
      "EnterWorktree",
      "ToolSearch",
      "TaskStop",
      "mcp__*"
    ],
    "ask": [],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(./secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(~/.gnupg/**)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(/etc/**)",
      "Write(/usr/**)",
      "Write(/System/**)",
      "Write(/root/**)",
      "Write(~/.gnupg/**)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(eval:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(init:*)"
    ]
  }
}
