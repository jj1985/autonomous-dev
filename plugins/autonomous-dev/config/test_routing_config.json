{
  "version": 1,
  "routing_rules": {
    "hook":          {"smoke": true, "unit_hooks": true, "regression": true, "genai": false, "property": false},
    "agent_prompt":  {"smoke": true, "unit": true, "regression": false, "genai": true, "property": false},
    "command":       {"smoke": true, "unit_commands": true, "regression": false, "genai": true, "property": false},
    "lib":           {"smoke": true, "unit_libs": true, "regression": true, "genai": false, "property": true},
    "config":        {"smoke": true, "unit": false, "regression": true, "genai": false, "property": false},
    "skill":         {"smoke": true, "unit_skills": true, "regression": false, "genai": true, "property": false},
    "docs_only":     {"smoke": false, "unit": false, "regression": false, "genai": false, "property": false},
    "install_sync":  {"smoke": true, "unit": true, "regression": true, "genai": false, "property": false}
  },
  "tier_to_marker": {
    "smoke": "smoke",
    "unit": "unit",
    "unit_hooks": "hooks",
    "unit_commands": "unit",
    "unit_libs": "unit",
    "unit_skills": "unit",
    "regression": "regression",
    "genai": "genai",
    "property": "property",
    "e2e": "e2e"
  },
  "tier_metadata": {
    "T0": {
      "name": "Permanent",
      "lifecycle": "permanent",
      "directories": ["tests/genai/", "tests/regression/smoke/"],
      "description": "Never delete. Critical path and acceptance validation."
    },
    "T1": {
      "name": "Stable",
      "lifecycle": "stable",
      "directories": ["tests/e2e/", "tests/integration/"],
      "description": "Delete only if the feature is removed."
    },
    "T2": {
      "name": "Semi-Stable",
      "lifecycle": "semi-stable",
      "directories": ["tests/regression/regression/", "tests/regression/extended/", "tests/property/"],
      "description": "Prune after 90 days unused."
    },
    "T3": {
      "name": "Ephemeral",
      "lifecycle": "ephemeral",
      "directories": ["tests/regression/progression/", "tests/unit/", "tests/hooks/", "tests/security/"],
      "description": "Prune freely. Implementation-coupled tests."
    }
  },
  "always_smoke": true,
  "docs_only_skip_all": true
}
